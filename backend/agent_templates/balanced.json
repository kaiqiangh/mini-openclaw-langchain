{
  "description": "General-purpose interactive profile aligned with the repo defaults and mild operator-friendly headroom.",
  "runtime_config": {
    "agent_runtime": {
      "max_steps": 24,
      "max_retries": 1
    },
    "llm_runtime": {
      "temperature": 0.2,
      "timeout_seconds": 75
    },
    "scheduler": {
      "api_enabled": true,
      "runs_query_default_limit": 150
    },
    "cron": {
      "enabled": true,
      "max_failures": 2
    }
  }
}
