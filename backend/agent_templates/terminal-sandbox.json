{
  "description": "Sandbox-required terminal profile with denylist-based command policy for broader local utility access without outbound network access.",
  "runtime_config": {
    "agent_runtime": {
      "max_steps": 18,
      "max_retries": 1
    },
    "tool_execution": {
      "terminal": {
        "sandbox_mode": "hybrid_auto",
        "command_policy_mode": "denylist",
        "require_sandbox": true,
        "allowed_command_prefixes": [],
        "denied_command_prefixes": [
          "git reset --hard",
          "git clean -fd",
          "git clean -fdx",
          "git checkout --",
          "docker compose down -v",
          "docker system prune",
          "docker volume prune",
          "rm -rf",
          "sudo rm -rf",
          "rm -rf /",
          "rm -rf --no-preserve-root",
          "dd if=",
          "shutdown",
          "reboot",
          "poweroff",
          "pkill -9",
          "killall -9",
          "chmod -R 777",
          "chown -R"
        ],
        "allow_network": false,
        "allow_shell_syntax": true,
        "max_args": 128,
        "max_arg_length": 4096
      }
    },
    "chat_enabled_tools": [
      "terminal",
      "apply_patch",
      "read_files",
      "read_pdf",
      "sessions_list",
      "session_history",
      "agents_list"
    ],
    "chat_blocked_tools": ["python_repl", "fetch_url", "web_search"],
    "scheduler": {
      "api_enabled": true,
      "runs_query_default_limit": 100
    }
  }
}
