{
  "description": "Local-safe template with tighter tool controls and conservative retries.",
  "runtime_config": {
    "agent_runtime": {
      "max_steps": 12,
      "max_retries": 0
    },
    "tool_execution": {
      "terminal": {
        "require_sandbox": true,
        "allow_network": false,
        "allow_shell_syntax": false
      }
    },
    "tool_network": {
      "block_private_networks": true,
      "max_redirects": 2
    },
    "scheduler": {
      "api_enabled": true,
      "runs_query_default_limit": 150
    }
  }
}
