{
  "description": "Code-editing profile for sandboxed local terminal work without outbound network access.",
  "runtime_config": {
    "agent_runtime": {
      "max_steps": 18,
      "max_retries": 1
    },
    "tool_execution": {
      "terminal": {
        "sandbox_mode": "hybrid_auto",
        "command_policy_mode": "allowlist",
        "require_sandbox": true,
        "allowed_command_prefixes": [
          "pwd",
          "date",
          "uname",
          "whoami",
          "id",
          "ls",
          "find",
          "file",
          "stat",
          "cat",
          "sed",
          "head",
          "tail",
          "wc",
          "cut",
          "sort",
          "uniq",
          "rg",
          "git status",
          "git diff",
          "git log",
          "git show",
          "git branch",
          "git rev-parse",
          "pytest",
          "python -m pytest",
          "npm test",
          "npm run",
          "node"
        ],
        "denied_command_prefixes": [
          "git reset --hard",
          "git clean -fd",
          "git clean -fdx",
          "git checkout --",
          "docker compose down -v",
          "docker system prune",
          "docker volume prune",
          "rm -rf",
          "sudo rm -rf",
          "rm -rf /",
          "rm -rf --no-preserve-root",
          "dd if=",
          "shutdown",
          "reboot",
          "poweroff",
          "pkill -9",
          "killall -9",
          "chmod -R 777",
          "chown -R"
        ],
        "allow_network": false,
        "allow_shell_syntax": false,
        "max_args": 24,
        "max_arg_length": 256
      }
    },
    "chat_enabled_tools": [
      "terminal",
      "apply_patch",
      "read_files",
      "read_pdf",
      "sessions_list",
      "session_history",
      "agents_list"
    ],
    "chat_blocked_tools": ["python_repl", "fetch_url", "web_search"],
    "scheduler": {
      "api_enabled": true,
      "runs_query_default_limit": 100
    }
  }
}
