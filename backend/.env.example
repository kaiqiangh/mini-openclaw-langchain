# Required for all protected /api/v1 routes
APP_ADMIN_TOKEN=change-me-local-token

# App runtime
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8000
APP_TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost

# Optional single-origin dev proxy for manual backend startup.
# `./oml start` enables this by default unless OML_ENABLE_FRONTEND_PROXY=inherit.
APP_ENABLE_FRONTEND_PROXY=false
APP_FRONTEND_PROXY_URL=http://127.0.0.1:3000

# Legacy fallback only when backend/config.json does not define llm_defaults.
# Use provider.model profile ids, for example: openai.gpt_4o_mini
DEFAULT_LLM_PROFILE=

# Tool-loop overrides now live in backend/config.json or backend/workspaces/<agent>/config.json
# under llm.tool_loop_model / llm.tool_loop_model_overrides.

# Provider credentials and endpoints.
# LLM model selection should be defined in backend/config.json -> llm_profiles / llm_defaults.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure AI Foundry (OpenAI-compatible mode)
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_BASE_URL=
AZURE_FOUNDRY_AUTH_HEADER=api-key
AZURE_FOUNDRY_API_KEY_ENV=AZURE_FOUNDRY_API_KEY
AZURE_FOUNDRY_DEFAULT_HEADERS_JSON=

# Embedding model configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY_ENV=OPENAI_API_KEY
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DEFAULT_HEADERS_JSON=

# Google AI Studio embedding configuration (used when EMBEDDING_PROVIDER=google_ai_studio)
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# Local coordination backend (no Redis required)
CONTROL_BACKEND=in_memory
CONTROL_DB_PATH=storage/control.db

# Optional tracing toggles (LangSmith)
LANGSMITH_TRACING=false
# Runtime override (optional)
OBS_TRACING_ENABLED=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mini-openclaw
