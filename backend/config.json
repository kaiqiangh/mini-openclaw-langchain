{
  "rag_mode": false,
  "injection_mode": "every_turn",
  "bootstrap_max_chars": 20000,
  "bootstrap_total_max_chars": 150000,
  "agent_runtime": {
    "max_steps": 50,
    "max_retries": 1
  },
  "llm_runtime": {
    "temperature": 1,
    "timeout_seconds": 60
  },
  "llm_profiles": {
    "deepseek": {
      "provider_id": "deepseek",
      "driver": "openai_compatible",
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY",
      "default_headers": {},
      "timeout_seconds": 60,
      "models": {
        "chat": "deepseek-chat",
        "reasoner": "deepseek-reasoner"
      }
    },
    "openai": {
      "provider_id": "openai",
      "driver": "openai_compatible",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "default_headers": {},
      "timeout_seconds": 60,
      "models": {
        "gpt_4o_mini": "gpt-4o-mini",
        "gpt_4_1_mini": "gpt-4.1-mini",
        "gpt_5_mini": "gpt-5-mini"
      }
    },
    "azure_foundry": {
      "provider_id": "azure_foundry",
      "driver": "openai_compatible",
      "base_url": "https://example.foundry.azure.com/openai/v1",
      "api_key_env": "AZURE_FOUNDRY_API_KEY",
      "default_headers": {
        "api-key": "${ENV:AZURE_FOUNDRY_API_KEY}"
      },
      "timeout_seconds": 60,
      "models": {
        "gpt_4o_mini": "gpt-4o-mini",
        "gpt_4_1_mini": "gpt-4.1-mini",
        "gpt_5_mini": "gpt-5-mini",
        "kimi_k2_5": "kimi-k2.5",
        "kimi_k2_thinking": "kimi-k2-thinking"
      }
    }
  },
  "llm_defaults": {
    "default": "deepseek.chat",
    "fallbacks": ["openai.gpt_4o_mini"],
    "fallback_policy": {
      "on_startup_missing_default": "warn",
      "on_runtime_auth_error": "fail",
      "on_timeout": "fallback",
      "on_rate_limit": "fallback",
      "on_5xx": "fallback",
      "on_network_error": "fallback"
    }
  },
  "agent_llm_overrides": {
    "example_agent": {
      "default": "azure_foundry.gpt_4_1_mini",
      "fallbacks": ["openai.gpt_4_1_mini"],
      "tool_loop_model_overrides": {
        "gpt-5-mini": "gpt-4.1-mini",
        "deepseek-reasoner": "deepseek-chat"
      },
      "fallback_policy": {
        "on_startup_missing_default": "warn",
        "on_runtime_auth_error": "fail",
        "on_timeout": "fallback",
        "on_rate_limit": "fallback",
        "on_5xx": "fallback",
        "on_network_error": "fallback"
      }
    }
  },
  "retrieval": {
    "memory": {
      "top_k": 3,
      "semantic_weight": 0.7,
      "lexical_weight": 0.3,
      "chunk_size": 256,
      "chunk_overlap": 32
    },
    "knowledge": {
      "top_k": 3,
      "semantic_weight": 0.7,
      "lexical_weight": 0.3,
      "chunk_size": 400,
      "chunk_overlap": 80
    },
    "storage": {
      "engine": "sqlite",
      "db_path": "storage/retrieval.db",
      "fts_prefilter_k": 50
    }
  },
  "tool_retry_guard": {
    "repeat_identical_failure_limit": 2
  },
  "tool_network": {
    "allow_http_schemes": ["http", "https"],
    "block_private_networks": true,
    "max_redirects": 3,
    "max_content_bytes": 2000000
  },
  "tool_timeouts": {
    "terminal_seconds": 30,
    "python_repl_seconds": 30,
    "fetch_url_seconds": 15
  },
  "tool_output_limits": {
    "terminal_chars": 5000,
    "fetch_url_chars": 5000,
    "read_file_chars": 10000
  },
  "tool_execution": {
    "terminal": {
      "sandbox_mode": "hybrid_auto",
      "command_policy_mode": "auto",
      "require_sandbox": true,
      "allowed_command_prefixes": [],
      "denied_command_prefixes": [
        "git reset --hard",
        "git clean -fd",
        "git clean -fdx",
        "git checkout --",
        "docker compose down -v",
        "docker system prune",
        "docker volume prune",
        "rm -rf",
        "sudo rm -rf",
        "rm -rf /",
        "rm -rf --no-preserve-root",
        "dd if=",
        "shutdown",
        "reboot",
        "poweroff",
        "pkill -9",
        "killall -9",
        "chmod -R 777",
        "chown -R"
      ],
      "allow_network": true,
      "allow_shell_syntax": true,
      "max_args": 128,
      "max_arg_length": 4096
    }
  },
  "chat_enabled_tools": [],
  "chat_blocked_tools": [],
  "autonomous_tools": {
    "heartbeat_enabled_tools": [],
    "cron_enabled_tools": [
      "web_search",
      "fetch_url",
      "read_files",
      "read_pdf",
      "search_knowledge_base",
      "sessions_list",
      "session_history",
      "agents_list",
      "scheduler_cron_jobs",
      "scheduler_cron_runs",
      "scheduler_heartbeat_status",
      "scheduler_heartbeat_runs"
    ]
  },
  "scheduler": {
    "api_enabled": true,
    "runs_query_default_limit": 100
  },
  "heartbeat": {
    "enabled": false,
    "interval_seconds": 300,
    "timezone": "UTC",
    "active_start_hour": 9,
    "active_end_hour": 21,
    "session_id": "__heartbeat__"
  },
  "cron": {
    "enabled": true,
    "poll_interval_seconds": 20,
    "timezone": "UTC",
    "max_failures": 2,
    "retry_base_seconds": 30,
    "retry_max_seconds": 3600,
    "failure_retention": 200
  },
  "delegation": {
    "enabled": true,
    "max_per_session": 5,
    "default_timeout_seconds": 120,
    "max_timeout_seconds": 600,
    "allowed_tool_scopes": {
      "researcher": ["web_search", "fetch_url", "read_files", "search_knowledge_base"],
      "analyst": ["read_files", "read_pdf", "search_knowledge_base", "terminal"],
      "writer": ["read_files", "search_knowledge_base", "apply_patch"]
    }
  }
}
