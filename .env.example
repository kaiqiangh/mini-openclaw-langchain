# Root Docker env file. docker compose loads this file into the backend/frontend containers.
# Override the path with COMPOSE_ENV_FILE=/path/to/file if needed.
#
# This file is intentionally smaller than backend/.env.example:
# - APP_ENABLE_FRONTEND_PROXY and APP_FRONTEND_PROXY_URL are not used by Docker.
#   Prod uses nginx as the public edge, and dev uses the frontend dev server rewrite.
# - DEFAULT_LLM_PROFILE is omitted because backend/config.json already defines llm_defaults.
#   The env var is only a legacy fallback when no effective default exists.

# Public ports used by docker compose.
STACK_PUBLIC_PORT=8080
BACKEND_DEV_PORT=8000
FRONTEND_DEV_PORT=3000

# Shared backend runtime settings.
APP_ADMIN_TOKEN=change-me-local-token
APP_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000
APP_TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost,backend-dev,nginx
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mini-openclaw

# Provider credentials injected at runtime. Leave blank until needed.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure AI Foundry / OpenAI-compatible mode.
# Most users only need AZURE_FOUNDRY_API_KEY and AZURE_FOUNDRY_BASE_URL.
# The remaining values are advanced overrides for non-default auth/header setups.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_BASE_URL=
AZURE_FOUNDRY_AUTH_HEADER=api-key
AZURE_FOUNDRY_API_KEY_ENV=AZURE_FOUNDRY_API_KEY
AZURE_FOUNDRY_DEFAULT_HEADERS_JSON=

# Embedding configuration.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY_ENV=OPENAI_API_KEY
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DEFAULT_HEADERS_JSON=
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# Local coordination backend.
CONTROL_BACKEND=in_memory
CONTROL_DB_PATH=storage/control.db

# Optional tracing override.
OBS_TRACING_ENABLED=
